# Public browser configuration. These values are safe to expose to the frontend.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
VITE_PROJECT_ID=YOUR_PROJECT_REF

# Never place service_role keys, database passwords, or Supabase access tokens here.
# Store server-only secrets with: supabase secrets set NAME=value
